# Production Environment Variables
# These variables are used in production builds

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Security
FORCE_HTTPS=true

# Performance
NEXT_CACHE_HANDLER=default

# Add your production-specific variables here
# PAGE_ACCESS_PASSWORD=your_production_password
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_production_service_id
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_production_template_id
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_production_public_key